# ══════════════════════════════════════════════════════════════════════════════
# Busch School Course Planner — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values marked REQUIRED.
# Never commit .env to version control.
#
# REQUIRED secrets are blank — the app will not work without them.
# OPTIONAL values have safe defaults; override as needed.
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────────────

APP_NAME="Busch Course Planner"
APP_ENV=production          # local | production
APP_KEY=                    # REQUIRED — run: php artisan key:generate
APP_DEBUG=false             # Never true in production
APP_URL=https://your-domain.com
# When rotating APP_KEY, add the old key here (comma-separated) so existing
# encrypted DB fields (full_name, gpa, grade, notes, placements) can still
# be decrypted until all rows are re-encrypted with the new key.
# APP_PREVIOUS_KEYS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12


# ── AI / Groq API ─────────────────────────────────────────────────────────────
# Sign up at https://console.groq.com — free tier available

GROQ_API_KEY=               # REQUIRED — starts with gsk_
GROQ_MODEL=llama-3.3-70b-versatile   # OPTIONAL — override to switch models


# ── Access Control ────────────────────────────────────────────────────────────
# Only email addresses ending in this domain can register and log in

ALLOWED_EMAIL_DOMAIN=cua.edu

# ── Seed User (php artisan db:seed) ───────────────────────────────────────────
# Credentials for the bootstrap admin account created by AdminUserSeeder.
# All three are REQUIRED — the seeder throws if any are missing.

ADMIN_SEED_EMAIL=                  # REQUIRED — e.g. admin@cua.edu
ADMIN_SEED_NAME=                   # REQUIRED — e.g. "Jane Smith"
ADMIN_SEED_PASSWORD=               # REQUIRED — strong unique password


# ── Database ──────────────────────────────────────────────────────────────────
#
# SQLite is fine for a single persistent server (VPS/dedicated).
# ⚠️  Heroku/Railway/Render: use Postgres — their filesystems are ephemeral and
#     will wipe a SQLite file on every dyno restart or redeploy.
#
# Heroku Postgres (free tier):
#   heroku addons:create heroku-postgresql:essential-0
#   heroku config sets DB_CONNECTION=pgsql (DATABASE_URL is set automatically)
#
# For Postgres, set DB_SSLMODE=require so the connection is encrypted in transit.

DB_CONNECTION=sqlite
# DB_CONNECTION=pgsql
# DB_URL=            # Heroku sets DATABASE_URL automatically; use this instead of the fields below
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=busch_planner
# DB_USERNAME=
# DB_PASSWORD=
# DB_SSLMODE=require


# ── Session ───────────────────────────────────────────────────────────────────

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE auto-enables in production; override here only if needed
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_EXPIRE_ON_CLOSE=false  # consider true for shared/lab computers


# ── Logging ───────────────────────────────────────────────────────────────────

LOG_CHANNEL=stack
LOG_DAILY_DAYS=14
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error


# ── Queue / Cache / Broadcast ─────────────────────────────────────────────────

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database


# ── Mail ──────────────────────────────────────────────────────────────────────
# Default: log driver (emails written to logs, not sent)
# For production: swap to smtp / mailgun / ses / postmark / resend

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"


# ── AWS (optional — only needed if using S3 or SES) ──────────────────────────

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false


# ── Redis (optional — only needed if using Redis for cache/sessions) ──────────

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379


# ── Frontend (Vite) ───────────────────────────────────────────────────────────

VITE_APP_NAME="${APP_NAME}"
